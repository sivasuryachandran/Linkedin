# Copy to backend/.env (or set in shell). Defaults match docker-compose.yml.

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=linkedin_user
MYSQL_PASSWORD=linkedin_pass
MYSQL_DATABASE=linkedin

MONGO_HOST=localhost
# Must match docker-compose host mapping (27018 -> container 27017). See README if auth fails.
MONGO_PORT=27018
MONGO_USER=mongo_user
MONGO_PASSWORD=mongo_pass
MONGO_DATABASE=linkedin
# Root user from MONGO_INITDB_ROOT_* lives in admin; required for Motor/PyMongo.
MONGO_AUTH_SOURCE=admin

REDIS_HOST=localhost
REDIS_PORT=6379

# Host machine must reach Kafka (docker maps 9094 -> broker EXTERNAL listener)
KAFKA_BOOTSTRAP_SERVERS=localhost:9094

# Optional: local Ollama for AI agents (http://localhost:11434). If down, APIs use heuristics.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
